<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<AnchorPane prefHeight="409.0" prefWidth="550.0" style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.xfty.homeworkchecker.controller.About">
   <children>
      <HBox alignment="CENTER" layoutY="40.0" prefHeight="77.0" prefWidth="550.0" spacing="10.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="40.0">
         <children>
            <ImageView fitHeight="52.0" fitWidth="46.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../icon/logo-classic.png" />
               </image>
            </ImageView>
            <Label text="HomeworkChecker" textFill="WHITE">
               <font>
                  <Font size="26.0" />
               </font>
            </Label>
         </children>
      </HBox>
      <Label alignment="CENTER" layoutX="14.0" layoutY="120.0" text="%about.title" textFill="WHITE" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <Label fx:id="versionDisplayAboutPage" alignment="CENTER" layoutX="15.0" layoutY="145.0" text="%about.version" textFill="WHITE" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="14.0" />
<Label alignment="CENTER" layoutX="14.0" layoutY="170.0" text="%about.openSourceVersion" textFill="WHITE" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" />
<Label alignment="CENTER" layoutX="14.0" layoutY="190.0" text="%about.githubInfo" textFill="WHITE" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" />
      <Label alignment="CENTER" layoutX="14.0" layoutY="230.0" text="%about.copyright" textFill="WHITE" AnchorPane.bottomAnchor="40.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" />
      <Label alignment="CENTER" layoutX="14.0" text="%about.opensource" textFill="WHITE" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" />
      <HBox alignment="CENTER" layoutY="260.0" prefHeight="46.0" prefWidth="550.0" spacing="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" onMouseClicked="#onUpdateWhatButtonClicked" styleClass="functional-button" stylesheets="@../../theme/darkness/button/functional-button.css" text="%about.updateLog">
               <graphic>
                  <ImageView fitHeight="20.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../icon/右上角箭头.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
         </children>
      </HBox>
      <HBox alignment="CENTER" layoutY="300.0" prefHeight="46.0" prefWidth="550.0" spacing="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
         <children>
            <Button mnemonicParsing="false" onMouseClicked="#onOpenSourceLicenseButtonClicked" styleClass="functional-button" stylesheets="@../../theme/darkness/button/functional-button.css" text="%about.openSourceLicense">
               <graphic>
                  <ImageView fitHeight="20.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../icon/右上角箭头.png" />
                     </image>
                  </ImageView>
               </graphic>
            </Button>
         </children>
      </HBox>
   </children>
</AnchorPane>
